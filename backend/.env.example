# === Server ===
PORT=8080
NODE_ENV=development

# === Database ===
# Overridden by docker-compose environment block when running in Docker
DATABASE_URL=postgresql://windom:windom@localhost:5432/windom

# === Auth secrets — generate with: openssl rand -base64 32 ===
JWT_ACCESS_SECRET=change-me-access-secret-32-chars-minimum-x
REFRESH_TOKEN_SECRET=change-me-refresh-secret-32-chars-minimum

# === AES-GCM key for OAuth token encryption — 32 random bytes, base64 encoded ===
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# === Google OAuth (for both sign-in and Calendar) ===
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/oauth/google/callback

# === Spotify OAuth ===
SPOTIFY_CLIENT_ID=<your-spotify-client-id>
SPOTIFY_CLIENT_SECRET=<your-spotify-client-secret>
SPOTIFY_REDIRECT_URI=http://localhost:8080/oauth/spotify/callback

# === CORS ===
CORS_ALLOWED_ORIGINS=chrome-extension://<your-chrome-extension-id>,http://localhost:3000,http://localhost:5173

# === Frontend ===
EXTENSION_REDIRECT_BASE=https://<your-chrome-extension-id>.chromiumapp.org
